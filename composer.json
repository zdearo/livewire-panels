{
    "name": "zdearo/livewire-panels",
    "description": "Developer-defined multi-panel foundation for Laravel and Livewire applications.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Zdearo\\LivewirePanels\\": "packages/panels/src/",
            "Zdearo\\LivewirePanels\\Support\\": "packages/support/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zdearo\\LivewirePanels\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "illuminate/auth": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "livewire/flux": "^2.14",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.4"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zdearo\\LivewirePanels\\LivewirePanelsServiceProvider"
            ],
            "aliases": {
                "Panels": "Zdearo\\LivewirePanels\\Facades\\Panels"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "refactor": "rector",
        "lint": "pint --parallel",
        "test:refactor": "rector --dry-run",
        "test:lint": "pint --parallel --test",
        "test:types": "phpstan analyse --ansi",
        "test:unit": "pest --colors=always --coverage --min=100 --parallel",
        "test": [
            "@test:refactor",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    }
}
